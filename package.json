{
  "name": "atlarium-mcp",
  "version": "1.0.0",
  "description": "Public read-only MCP server for Atlarium freshwater aquarium data.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit --pretty false",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "mcp:conformance": "npx @modelcontextprotocol/conformance server --url http://localhost:43118/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
